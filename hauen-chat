if (!defined('ABSPATH')) exit;

// --- DATABASE SETUP ---
global $wpdb;
$wpdb->hauen_chat_messages = $wpdb->prefix . 'hauen_chat_messages';

function hauen_chat_create_table() {
    global $wpdb;
    $charset_collate = $wpdb->get_charset_collate();
    $sql = "CREATE TABLE IF NOT EXISTS {$wpdb->hauen_chat_messages} (
        id bigint(20) NOT NULL AUTO_INCREMENT,
        user_id bigint(20) DEFAULT NULL,
        user_name varchar(100) DEFAULT NULL,
        message text NOT NULL,
        role varchar(20) NOT NULL,
        timestamp datetime NOT NULL DEFAULT CURRENT_TIMESTAMP,
        PRIMARY KEY (id)
    ) $charset_collate;";
    require_once(ABSPATH . 'wp-admin/includes/upgrade.php');
    dbDelta($sql);
}
register_activation_hook(__FILE__, 'hauen_chat_create_table');

// --- REST API ENDPOINTS ---
add_action('rest_api_init', function() {
    register_rest_route('hauen-chat/v1', '/send-message', [
        'methods' => 'POST',
        'callback' => 'hauen_chat_send_message',
        'permission_callback' => 'hauen_chat_check_permission',
    ]);
    register_rest_route('hauen-chat/v1', '/get-messages', [
        'methods' => 'GET',
        'callback' => 'hauen_chat_get_messages',
        'permission_callback' => 'hauen_chat_check_permission',
    ]);
});

function hauen_chat_send_message($request) {
    $params = $request->get_json_params();
    $user_id = get_current_user_id();
    $user_name = $user_id ? wp_get_current_user()->display_name : 'Guest';
    $role = $user_id ? hauen_chat_get_user_role($user_id) : 'guest';
    $message = sanitize_text_field($params['message']);

    global $wpdb;
    $wpdb->insert($wpdb->hauen_chat_messages, [
        'user_id' => $user_id,
        'user_name' => $user_name,
        'message' => $message,
        'role' => $role,
    ]);

    return new WP_REST_Response(['success' => true], 200);
}

function hauen_chat_get_messages($request) {
    global $wpdb;
    $messages = $wpdb->get_results(
        "SELECT * FROM {$wpdb->hauen_chat_messages} ORDER BY timestamp DESC LIMIT 50"
    );
    return new WP_REST_Response($messages, 200);
}

function hauen_chat_get_user_role($user_id) {
    $user = get_userdata($user_id);
    return $user ? array_shift($user->roles) : 'guest';
}

function hauen_chat_check_permission() {
    if (is_user_logged_in()) return true;
    $password = isset($_POST['guest_password']) ? sanitize_text_field($_POST['guest_password']) : '';
    return $password === get_option('hauen_chat_guest_password', '');
}

// --- FRONTEND (JS/CSS embedded) ---
add_action('wp_enqueue_scripts', function() {
    wp_enqueue_style('hauen-chat-css', plugins_url('hauen-chat.css', __FILE__));
    wp_enqueue_script('hauen-chat-js', plugins_url('hauen-chat.js', __FILE__), ['jquery'], '1.0', true);
    wp_localize_script('hauen-chat-js', 'hauenChatVars', [
        'nonce' => wp_create_nonce('wp_rest'),
    ]);
});

add_shortcode('hauen_chat', function() {
    ob_start(); ?>
    <div id="hauen-chat-container">
        <div id="hauen-chat-messages" style="
            height: 300px;
            overflow-y: auto;
            margin-bottom: 10px;
            border: 1px solid #ddd;
            padding: 10px;
            font-family: Arial, sans-serif;
        "></div>
        <form id="hauen-chat-form" style="display: flex;">
            <input type="text" id="hauen-chat-message" placeholder="Type your message..." style="
                flex: 1;
                padding: 5px;
            ">
            <button type="submit" style="
                padding: 5px 10px;
                margin-left: 5px;
            ">Send</button>
        </form>
    </div>
    <script>
    jQuery(document).ready(function($) {
        const $messages = $('#hauen-chat-messages');
        const $form = $('#hauen-chat-form');
        const $input = $('#hauen-chat-message');

        function loadMessages() {
            $.ajax({
                url: '/wp-json/hauen-chat/v1/get-messages',
                method: 'GET',
                beforeSend: function(xhr) {
                    xhr.setRequestHeader('X-WP-Nonce', hauenChatVars.nonce);
                },
                success: function(messages) {
                    $messages.empty();
                    messages.reverse().forEach(msg => {
                        $messages.append(
                            `<div style="
                                padding: 5px;
                                margin-bottom: 5px;
                                border-radius: 5px;
                                background: ${msg.role === 'admin' ? '#ffebee' : msg.role === 'member' ? '#e8f5e9' : '#e3f2fd'};
                            ">
                                <strong>${msg.user_name} (${msg.role})</strong>: ${msg.message}
                            </div>`
                        );
                    });
                }
            });
        }

        $form.on('submit', function(e) {
            e.preventDefault();
            const message = $input.val().trim();
            if (!message) return;

            $.ajax({
                url: '/wp-json/hauen-chat/v1/send-message',
                method: 'POST',
                data: JSON.stringify({ message }),
                contentType: 'application/json',
                beforeSend: function(xhr) {
                    xhr.setRequestHeader('X-WP-Nonce', hauenChatVars.nonce);
                },
                success: function() {
                    $input.val('');
                    loadMessages();
                }
            });
        });

        loadMessages();
        setInterval(loadMessages, 5000);
    });
    </script>
    <?php return ob_get_clean();
});

